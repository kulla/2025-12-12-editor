{
  "name": "rsbuild-react-bun-biome-starter-template",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "check": "bun run check:tsc && bun run check:lint",
    "check:lint": "biome check --write",
    "check:tsc": "tsc --noEmit",
    "dev": "rsbuild dev --open",
    "format": "biome format --write",
    "preview": "rsbuild preview"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "es-toolkit": "1.45.1",
    "prosekit": "0.18.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "y-prosemirror": "1.3.7",
    "y-protocols": "1.0.7",
    "yjs": "13.6.30"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@playwright/test": "1.59.1",
    "@rsbuild/core": "1.7.5",
    "@rsbuild/plugin-react": "1.4.6",
    "@tailwindcss/postcss": "4.2.2",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2"
  }
}
